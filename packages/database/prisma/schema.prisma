// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 1. THE BRAND (USER) ---
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  
  // Brand Identity
  brandName String?
  slug      String?  @unique // The Public Link (e.g. 'drip-kult')
  logoUrl   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- 🔪 SURGERY: PAYMENT ROUTING FIELDS ---
  plan                    String  @default("STARTER") // "STARTER" | "PRO"
  razorpayKeyId           String? // For Pro: BYOG
  razorpayKeySecret       String? // For Pro: BYOG
  razorpayLinkedAccountId String? // For Starter: Route/Linked Accounts
  // ------------------------------------------

  // --- 📱 WHATSAPP BUSINESS API FIELDS ---
  whatsappPhoneNumberId   String?  // Meta Phone Number ID
  whatsappToken           String?  // Meta Permanent Access Token
  whatsappEnabled         Boolean  @default(false)
  // ----------------------------------------

  // --- 💸 UPI PAYMENT FIELDS ---
  upiId                   String?  // Brand's UPI ID (e.g. brandname@okaxis)
  paymentMode             String   @default("RAZORPAY_PLATFORM") // "RAZORPAY_PLATFORM" | "RAZORPAY_BYOG" | "UPI_DIRECT"
  // ----------------------------
  
  // Relations
  products     Product[]
  transactions Transaction[]
  payouts      Payout[]
  customers    Customer[]
  orders       Order[]
}

// --- 2. THE PRODUCT (Restored) ---
model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique
  checkoutSlug String  @unique
  description String?
  basePrice   Decimal  // Use Decimal for money math
  productDropDate DateTime? // When the product goes live
  images      String[] // Array of Cloudinary URLs

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  variants    Variant[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- 3. THE VARIANTS (Sizes/Colors) ---
model Variant {
  id              String  @id @default(uuid())
  name            String  // e.g. "Size M"
  inventoryCount  Int     @default(0)
  reservedCount   Int     @default(0)
  priceAdjustment Decimal @default(0)
  price           Decimal @default(0) // ADDED: Directly store the price
  imageUrl        String? // ADDED: Specific image for the variant

  productId       String
  product         Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // ADD THIS LINE: Relation to CartReservation
  cartReservations CartReservation[] 
}

// --- 4. THE MONEY LEDGER ---
model Transaction {
  id                   String   @id @default(uuid())

  userId               String
  user                 User     @relation(fields: [userId], references: [id])

  orderId              String?
  order                Order?   @relation(fields: [orderId], references: [id])

  // Razorpay Audit Trail
  razorpayOrderId      String   @unique
  razorpayPaymentId    String?
  razorpaySettlementId String?

  // The Math (Decimal — never Float for money)
  grossAmount          Decimal
  platformFee          Decimal
  razorpayFee          Decimal  @default(0)
  netAmount            Decimal

  // State machine: CAPTURED | SETTLED | PAID_OUT | REFUNDED
  status               String   @default("CAPTURED")

  // Settlement Timeline
  settlementEta        DateTime?
  capturedAt           DateTime @default(now())
  settledAt            DateTime?
  paidOutAt            DateTime?

  // Payout linkage
  payoutId             String?
  payout               Payout?  @relation(fields: [payoutId], references: [id])

  createdAt            DateTime @default(now())

  @@index([userId, status]) // Fast balance calculations
}

// --- 4b. PAYOUT RECORD ---
model Payout {
  id               String   @id @default(uuid())

  userId           String
  user             User     @relation(fields: [userId], references: [id])

  amount           Decimal
  status           String   // INITIATED | SUCCESS | FAILED
  razorpayPayoutId String?

  processedAt      DateTime?
  createdAt        DateTime @default(now())

  transactions     Transaction[]
}

// --- 5. CRM & ORDERS (Restored for Checkout) ---

model Customer {
  id          String   @id @default(uuid())
  
  userId      String   // The Brand this customer belongs to
  user        User     @relation(fields: [userId], references: [id])
  
  name        String
  phone       String
  email       String?
  
  totalSpent  Decimal  @default(0)
  totalOrders Int      @default(0)
  lastOrderAt DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  orders      Order[]
  addresses   Address[]
  
  @@index([userId, phone]) // Fast lookup for repeat customers
}

model Address {
  id           String   @id @default(uuid())
  
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  
  addressLine1 String
  city         String
  state        String
  pincode      String
  isDefault    Boolean  @default(false)
  
  orders       Order[]
}

model Order {
  id              String   @id @default(uuid())
  orderNumber     String   @unique // ORD-TIMESTAMP-RANDOM
  
  userId          String   // The Brand
  user            User     @relation(fields: [userId], references: [id])
  
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  
  addressId       String
  address         Address  @relation(fields: [addressId], references: [id])
  
  razorpayOrderId   String @unique
  razorpayPaymentId String?
  
  // Financials
  subtotal        Decimal
  shippingFee     Decimal  @default(0)
  total           Decimal
  
  paymentStatus   String   // 'paid', 'pending', 'failed', 'upi_pending'
  status          String   // 'processing', 'confirmed', 'shipped', 'delivered'
  productDropDate DateTime?
  paidAt          DateTime?

  // UPI-specific fields
  utrNumber              String?  // Customer-submitted UTR after UPI payment
  upiVerificationStatus  String?  // 'AWAITING' | 'CONFIRMED' | 'DISPUTED'
  
  items           OrderItem[]
  transactions    Transaction[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id          String   @id @default(uuid())
  
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  
  productId   String
  variantId   String
  
  productName String
  variantName String
  price       Decimal
  quantity    Int
}

model WebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType   String
  payload     Json
  processedAt DateTime @default(now())
}


model CartReservation {
  id        String   @id @default(uuid())
  variantId String
  sessionId String
  quantity  Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  variant   Variant @relation(fields: [variantId], references: [id])

  // ADD THESE INDEXES
  @@index([expiresAt]) // Critical for the Cron Job cleanup
  @@index([sessionId]) // Critical for looking up a user's cart
  @@index([variantId]) // Critical for checking product availability
}

model IdempotencyKey {
  key          String   @id
  responseBody Json
  status       String   // 'PROCESSING', 'COMPLETED'
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// --- 6. WAITLIST (New) ---
model Waitlist {
  id        String   @id @default(uuid())
  brandName String
  instagram String
  email     String
  createdAt DateTime @default(now())
}
